# 🔐 Kaggle API Credentials (Required for dataset download)
# Get them from: https://www.kaggle.com/settings/account -> Create New Token
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_api_key_here

# 📊 Optional: MLflow Tracking URI (defaults to local SQLite if omitted)
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db