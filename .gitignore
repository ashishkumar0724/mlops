# Your existing .gitignore should include:

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-wheel-metadata/

# ML/Data
*.pkl
*.joblib
*.parquet
*.csv
*.tsv
!data/raw/.gitkeep
!data/processed/.gitkeep

# MLflow
mlflow.db
mlruns/*/artifacts/
mlruns/*/metrics/
mlruns/*/params/
mlruns/*/tags/

# Logs & Temp
logs/*.log
*.log
tmp/
.temp/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
!.env.example

# OS
.DS_Store
Thumbs.db

# Docker (optional - keep Dockerfile, ignore build artifacts)
*.dockerignore